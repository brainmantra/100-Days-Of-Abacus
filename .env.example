# Copy this file to .env and fill in real values.
# .env is git-ignored and must NEVER be committed.

# Base URL of the backend API (used by the Vite frontend).
# In development with the Vite proxy configured, leave this blank.
# In production, set this to your deployed API URL, e.g.:
# VITE_API_URL=https://your-api.railway.app/api
VITE_API_URL=
